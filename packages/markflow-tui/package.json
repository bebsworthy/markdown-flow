{
  "name": "markflow-tui",
  "version": "0.0.0",
  "private": true,
  "description": "Terminal UI for the markflow workflow engine.",
  "type": "module",
  "bin": {
    "markflow-tui": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
