{
  "name": "markflow-cli",
  "version": "0.1.7",
  "license": "MIT",
  "description": "Workflow engine driven by Markdown + Mermaid flowcharts",
  "repository": {
    "type": "git",
    "url": "https://github.com/bebsworthy/markdown-flow.git",
    "directory": "packages/markflow"
  },
  "homepage": "https://github.com/bebsworthy/markdown-flow#readme",
  "keywords": [
    "workflow",
    "markdown",
    "mermaid",
    "cli",
    "automation",
    "ai-agent"
  ],
  "type": "module",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "bin": {
    "markflow": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "mermaid-ast": "^0.8.2",
    "chalk": "^5.3.0",
    "js-yaml": "^4.1.1",
    "liquidjs": "^10.25.7",
    "proper-lockfile": "^4.1.2",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/yargs": "^17.0.35",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
